# Copy to .env in the project root (never commit .env)
# Restart `npm run dev` after changing env vars.
#
# EmailJS dashboard: https://dashboard.emailjs.com/
# 1. Email Services → connect your inbox (Gmail, etc.)
# 2. Email Templates → create a template with these variables:
#    {{from_name}} {{from_email}} {{reply_to}} {{subject}} {{message}}
# 3. Account → API Keys → Public Key

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
